# Supabase connection — copy this file to `.env.local` and fill in the values.
# Find them in the Supabase dashboard → your project → Connect → Framework (Next.js).
# The publishable key is safe to expose to the browser (NEXT_PUBLIC_*); never put
# the service_role / secret key in a NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# OpenAI — server-only (captions, and optionally AI images). NEVER NEXT_PUBLIC.
OPENAI_API_KEY=sk-your-openai-key-here

# Server-only — Supabase secret key. Used ONLY by the draft-cleanup cron (acts
# across users / bypasses RLS). NEVER prefix with NEXT_PUBLIC.
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
# Shared secret protecting the cleanup cron endpoint (any random string).
CRON_SECRET=your-random-cron-secret

# TikTok Content Posting API — from developers.tiktok.com → your app → app details.
# NEVER prefix with NEXT_PUBLIC. Client key is used server-side only.
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
# Your deployed app URL (no trailing slash). Used to build OAuth redirect URIs + image proxy URLs.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
